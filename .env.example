# Copie para .env e preencha com valores reais. NUNCA versione o .env.

# Supabase: pegue em Project Settings > Database > Connection string.
# IMPORTANTE: para deploy serverless (Vercel), use a "Connection pooling"
# string (porta 6543, modo transaction) — não a conexão direta (porta 5432).
# Conexão direta esgota rápido em ambiente serverless, onde cada invocação
# pode abrir uma conexão nova.
DATABASE_URL=postgresql://app_fluxo.xxxxxxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Conexão privilegiada — role DONA das tabelas (ex: "postgres" no Supabase),
# ignora RLS. Usar SÓ em login/cadastro (busca por e-mail, antes de saber o
# profissional_id), webhook do Asaas e no job de faturamento (varredura
# cross-tenant). Nunca usar para servir dado de cliente de um profissional.
#
# A role "app_fluxo" usada acima em DATABASE_URL precisa ser criada uma vez
# no banco, sem BYPASSRLS (senão o RLS multi-tenant não é respeitado):
#   CREATE ROLE app_fluxo LOGIN PASSWORD '...' NOSUPERUSER NOBYPASSRLS;
#   GRANT USAGE ON SCHEMA public TO app_fluxo;
#   GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO app_fluxo;
#   GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO app_fluxo;
DATABASE_URL_ADMIN=postgresql://postgres.xxxxxxxx:senha@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

JWT_SECRET_KEY=troque_por_uma_chave_aleatoria_longa
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Provedor Open Finance (preencher depois de fechar com a Pluggy/Tecnospeed)
OPENFINANCE_CLIENT_ID=
OPENFINANCE_CLIENT_SECRET=
OPENFINANCE_WEBHOOK_SECRET=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gateway de pagamento (cobrança do profissional)
PAYMENT_GATEWAY_SECRET_KEY=

# Asaas — cobrança recorrente do profissional
# Sandbox pra testar sem dinheiro real: https://sandbox.asaas.com
ASAAS_API_KEY=
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=
